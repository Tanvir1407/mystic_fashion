generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Discount {
  id           String       @id @default(uuid())
  name         String
  discountType DiscountType @default(FLAT)
  value        Float
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  products     Product[]
}

model Admin {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      AdminRole @default(MANAGER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  roleId    String?
  rbacRole  Role?     @relation(fields: [roleId], references: [id])
}

model Staff {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roleId    String?
  role      Role?    @relation(fields: [roleId], references: [id])
  orders    Order[]
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  admins      Admin[]
  staff       Staff[]
  permissions Permission[] @relation("PermissionToRole")
}

model Permission {
  id      String @id @default(uuid())
  action  String
  subject String
  roles   Role[] @relation("PermissionToRole")

  @@unique([action, subject])
}

model SizeChart {
  id        String    @id @default(uuid())
  category  String    @unique
  data      Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  products      Product[]
  subcategories Subcategory[]
}

model Subcategory {
  id         String    @id @default(uuid())
  name       String
  categoryId String
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products   Product[]

  @@unique([name, categoryId])
}

model Product {
  id            String           @id @default(uuid())
  name          String
  description   String
  price         Float
  purchasePrice Float?
  images        String[]
  team          String?
  category      String
  brandId       String?
  categoryId    String?
  subcategoryId String?
  sizeChartId   String?
  discountId    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  isFeatured    Boolean          @default(false)
  isPublished   Boolean          @default(true)
  isCustomize   Boolean?         @default(false)
  orderItems    OrderItem[]
  brand         Brand?           @relation(fields: [brandId], references: [id])
  categoryRel   Category?        @relation(fields: [categoryId], references: [id])
  subcategory   Subcategory?     @relation(fields: [subcategoryId], references: [id])
  discount      Discount?        @relation(fields: [discountId], references: [id])
  sizeChart     SizeChart?       @relation(fields: [sizeChartId], references: [id])
  variants      ProductVariant[]
  purchaseItems PurchaseItem[]
}

model ProductVariant {
  id               String            @id @default(uuid())
  productId        String
  size             String
  color            String            @default("Default")
  colorCode        String?
  sku              String?           @unique
  stock            Int               @default(0)
  order            Int               @default(0)
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchaseItems    PurchaseItem[]
  salesReturns     SalesReturn[]
  stockAdjustments StockAdjustment[]

  @@unique([productId, size, color])
}

model Order {
  id                  String        @id @default(uuid())
  customerName        String
  phone               String
  district            String        @default("Dhaka")
  address             String
  totalAmount         Float
  status              OrderStatus   @default(PENDING)
  orderSource         OrderSource   @default(Salesman)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  advancePaid         Float         @default(0)
  couponCode          String?
  discountAmount      Float         @default(0)
  remarks             String?
  bkashNumber         String?
  bkashTrxId          String?
  pathaoAreaId        Int?
  pathaoCityId        Int?
  pathaoConsignmentId String?
  pathaoZoneId        Int?
  createdById         String?
  createdBy           Staff?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  coupon              Coupon?       @relation(fields: [couponCode], references: [code])
  items               OrderItem[]
  salesReturns        SalesReturn[]
}

model Coupon {
  id        String     @id @default(cuid())
  code      String     @unique
  type      CouponType @default(FLAT)
  value     Float
  startDate DateTime?
  endDate   DateTime?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  orders    Order[]
}

model OrderItem {
  id            String        @id @default(uuid())
  orderId       String
  productId     String
  size          String        @default("M")
  quantity      Int
  price         Float
  printCost     Float         @default(0)
  printName     String?
  printNumber   String?
  requiresPrint Boolean       @default(false)
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
  salesReturns  SalesReturn[]
}

model DeliverySetting {
  id           String   @id @default("default")
  insideDhaka  Int      @default(80)
  outsideDhaka Int      @default(150)
  updatedAt    DateTime @updatedAt
}

model InventorySetting {
  id                String   @id @default("default")
  lowStockThreshold Int      @default(5)
  updatedAt         DateTime @updatedAt
}

model DTFPrintSetting {
  id        String   @id @default("default")
  printCost Int      @default(300)
  updatedAt DateTime @updatedAt
}

model HeroSlide {
  id        String   @id @default(uuid())
  image     String
  link      String   @default("/shop")
  label     String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Purchase {
  id             String         @id @default(uuid())
  supplierName   String
  invoiceNumber  String?
  totalAmount    Float
  status         String         @default("PENDING")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  discountAmount Float          @default(0)
  items          PurchaseItem[]
}

model PurchaseItem {
  id         String         @id @default(uuid())
  purchaseId String
  productId  String
  variantId  String
  quantity   Int
  unitPrice  Float
  product    Product        @relation(fields: [productId], references: [id])
  purchase   Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id])
}

model FooterConfig {
  id             String   @id @default("default")
  aboutText      String   @default("Premium authentic jerseys and sportswear. Crafted for those who live and breathe the game.")
  facebookUrl    String   @default("#")
  instagramUrl   String   @default("#")
  whatsappPhone  String?  @default("")
  companyLinks   Json     @default("[{\"url\": \"/about\", \"label\": \"About\"}, {\"url\": \"/contact\", \"label\": \"Contact\"}, {\"url\": \"/faq\", \"label\": \"FAQ\"}]")
  contactEmail   String   @default("hello@mysticfashion.com")
  contactPhone   String   @default("01700-MYSTIC")
  contactAddress String   @default("Dhaka, Bangladesh")
  updatedAt      DateTime @updatedAt
}

model Page {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChartOfAccount {
  id           String        @id @default(uuid())
  name         String        @unique
  type         AccountType
  status       AccountStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Transaction {
  id            String          @id @default(uuid())
  accountId     String
  amount        Float
  date          DateTime
  type          TransactionType
  description   String
  referenceId   String?
  referenceType String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  account       ChartOfAccount  @relation(fields: [accountId], references: [id])
}

model ApiToken {
  id           String   @id @default("pathao")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt
}

model StockAdjustment {
  id               String         @id @default(uuid())
  variantId        String
  adjustmentType   AdjustmentType
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  reason           String?
  adjustedBy       String?
  createdAt        DateTime       @default(now())
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model SalesReturn {
  id           String         @id @default(uuid())
  orderId      String
  orderItemId  String
  variantId    String
  quantity     Int
  returnReason String
  status       ReturnStatus
  deliveryLoss Float          @default(0)
  productLoss  Float          @default(0)
  printingLoss Float          @default(0)
  processedBy  String?
  createdAt    DateTime       @default(now())
  order        Order          @relation(fields: [orderId], references: [id])
  orderItem    OrderItem      @relation(fields: [orderItemId], references: [id])
  variant      ProductVariant @relation(fields: [variantId], references: [id])
}

model LabelSetting {
  id          String   @id @default("default")
  widthMm     Int      @default(50)
  heightMm    Int      @default(25)
  showName    Boolean  @default(true)
  showPrice   Boolean  @default(true)
  showSKU     Boolean  @default(true)
  showBarcode Boolean  @default(true)
  showQR      Boolean  @default(false)
  fontSize    Int      @default(8)
  updatedAt   DateTime
}

enum DiscountType {
  FLAT
  PERCENTAGE
}

enum CouponType {
  FLAT
  PERCENTAGE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKAGING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  PRINTING
}

enum OrderSource {
  eCommerce
  Salesman
}

enum AdminRole {
  SUPERADMIN
  MANAGER
}

enum AccountType {
  INCOME
  EXPENSE
  ASSET
  LIABILITY
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum TransactionType {
  DEBIT
  CREDIT
}

enum AdjustmentType {
  ADDITION
  SUBTRACTION
  SET
}

enum ReturnStatus {
  RESTOCKED
  WASTAGE
}

// ─── AUDIT TRAIL ──────────────────────────────────────────────────────────────

model ActivityLog {
  id            String      @id @default(uuid())

  // ─── WHO ─────────────────────────────────────────────────
  userId        String                    // Staff/Admin UUID
  userEmail     String?                   // Denormalized for quick display
  userRole      String?                   // e.g. "SUPERADMIN", "MANAGER"

  // ─── WHAT ────────────────────────────────────────────────
  action        AuditAction               // CREATE, UPDATE, DELETE
  entityType    String                    // e.g. "Product", "Order", "Transaction"
  entityId      String                    // The UUID/ID of the affected record
  description   String?                   // Human-readable summary
  dataBefore    Json?                     // JSONB snapshot BEFORE mutation (null for CREATE)
  dataAfter     Json?                     // JSONB snapshot AFTER mutation (null for DELETE)
  changedFields String[]                  // Array of field names that changed (for UPDATE)

  // ─── WHEN ────────────────────────────────────────────────
  timestamp     DateTime    @default(now())

  // ─── WHERE ───────────────────────────────────────────────
  ipAddress     String?                   // Extracted from request headers
  userAgent     String?                   // Browser/device info

  // ─── INDEXING ────────────────────────────────────────────
  @@index([userId])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@index([action])
}

model AuditLogSetting {
  id                String   @id @default("default")
  retentionDays     Int?                  // null = keep indefinitely (default)
  updatedAt         DateTime @updatedAt
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}
