generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Discount {
  id           String       @id @default(uuid())
  name         String
  discountType DiscountType @default(FLAT)
  value        Float
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
  products     Product[]

  @@index([deletedAt])
}

model Admin {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      AdminRole @default(MANAGER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  roleId    String?
  rbacRole  Role?     @relation(fields: [roleId], references: [id])
}

model Staff {
  id                 String              @id @default(uuid())
  username           String              @unique
  email              String              @unique
  password           String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  roleId             String?
  hasPortalAccess    Boolean             @default(false)
  commissionRate     Float?
  role               Role?               @relation(fields: [roleId], references: [id])
  orders             Order[]
  commissionPayments CommissionPayment[]
}

model CommissionSetting {
  id             String   @id @default("default")
  commissionRate Float    @default(10)
  updatedAt      DateTime @updatedAt
}

model CommissionPayment {
  id        String   @id @default(uuid())
  staffId   String
  amount    Float
  month     Int
  year      Int
  note      String?
  paidAt    DateTime @default(now())
  paidById  String?
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([year, month])
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  admins      Admin[]
  staff       Staff[]
  permissions Permission[] @relation("PermissionToRole")
}

model Permission {
  id      String @id @default(uuid())
  action  String
  subject String
  roles   Role[] @relation("PermissionToRole")

  @@unique([action, subject])
}

model SizeChart {
  id        String    @id @default(uuid())
  category  String    @unique
  data      Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  products  Product[]

  @@index([deletedAt])
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  active        Boolean       @default(true)
  image         String?       // Custom homepage image URL (uploaded via admin)
  sortOrder     Int           @default(0) // Homepage display order (lower = first)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  products      Product[]
  subcategories Subcategory[]
  attributeMappings CategoryAttributeMapping[]

  @@index([deletedAt])
  @@index([sortOrder])
}

model Subcategory {
  id         String    @id @default(uuid())
  name       String
  categoryId String
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  products   Product[]

  @@unique([name, categoryId])
  @@index([categoryId])
  @@index([deletedAt])
}

model Product {
  id            String           @id @default(uuid())
  name          String
  slug          String?          @unique
  description   String
  team          String?
  category      String
  brandId       String?
  categoryId    String?
  subcategoryId String?
  sizeChartId   String?
  discountId    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?
  isFeatured    Boolean          @default(false)
  featuredOrder Int              @default(0)
  isPublished   Boolean          @default(true)
  isCustomize   Boolean?         @default(false)
  trackStock    Boolean?         @default(false)
  price         Float?
  purchasePrice Float?
  images        String[]         @default([])
  orderItems    OrderItem[]
  brand         Brand?           @relation(fields: [brandId], references: [id])
  categoryRel   Category?        @relation(fields: [categoryId], references: [id])
  subcategory   Subcategory?     @relation(fields: [subcategoryId], references: [id])
  discount      Discount?        @relation(fields: [discountId], references: [id])
  sizeChart     SizeChart?       @relation(fields: [sizeChartId], references: [id])
  variants      ProductVariant[]
  purchaseItems PurchaseItem[]
  mediaAssets   MediaAsset[]

  @@index([deletedAt])
  @@index([brandId])
  @@index([categoryId])
  @@index([subcategoryId])
}

model ProductVariant {
  id               String            @id @default(uuid())
  productId        String
  size             String
  color            String            @default("Default")
  colorCode        String?
  sku              String?           @unique
  order            Int               @default(0)
  upc              String?           @unique
  qrCode           String?           @unique
  attributes       Json              @default("{}")
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchaseItems    PurchaseItem[]
  salesReturns     SalesReturn[]
  stockAdjustments StockAdjustment[]
  stocks           Stock[]
  pricingMatrix    VariantPricingMatrix?
  orderItems       OrderItem[]

  @@unique([productId, size, color])
  @@index([productId])
}

model Order {
  id                  String        @id @default(uuid())
  customerName        String
  phone               String
  district            String        @default("Dhaka")
  address             String
  totalAmount         Float
  status              OrderStatus   @default(PENDING)
  orderSource         OrderSource   @default(Salesman)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?
  advancePaid         Float         @default(0)
  couponCode          String?
  discountAmount      Float         @default(0)
  remarks             String?
  specialInstruction  String?
  bkashNumber         String?
  bkashTrxId          String?
  pathaoAreaId        Int?
  pathaoCityId        Int?
  pathaoConsignmentId String?
  pathaoZoneId        Int?
  isStorePickup   Boolean @default(false)
  deliveryCharge  Float   @default(0)
  isExchange         Boolean @default(false)
  exchangeRefOrderId String?
  exchangeItemNote   String?
  tags               String[]      @default([])
  createdById         String?
  customerId          String?
  commissionRate      Float?
  createdBy           Staff?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  customer            Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  coupon              Coupon?       @relation(fields: [couponCode], references: [code])
  couponUsage         CouponUsage?
  items               OrderItem[]
  salesReturns        SalesReturn[]
  exchangeRefOrder   Order?  @relation("ExchangeOrders", fields: [exchangeRefOrderId], references: [id], onDelete: SetNull)
  exchangeOrders     Order[] @relation("ExchangeOrders")

  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([customerId])
  @@index([phone])
}

model Coupon {
  id                  String        @id @default(cuid())
  code                String        @unique
  type                CouponType    @default(FLAT)
  value               Float
  startDate           DateTime?
  endDate             DateTime?
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?
  orders              Order[]

  // Advanced Limits & Conditions
  minCartValue        Float?
  maxCartValue        Float?
  maxDiscountAmount   Float?
  excludeSaleItems    Boolean       @default(false)
  usageLimitTotal     Int?
  usageLimitPerUser   Int           @default(1)
  customerSegment     String?       // 'ALL', 'NEW_USER', 'VIP'

  // Whitelists & Blacklists
  includedProductIds  String[]      @default([])
  excludedProductIds  String[]      @default([])
  includedCategoryIds String[]      @default([])
  excludedCategoryIds String[]      @default([])

  usages              CouponUsage[]
  locks               CouponLock[]

  @@index([deletedAt])
}

model CouponUsage {
  id             String   @id @default(uuid())
  couponId       String
  customerId     String?
  phone          String
  orderId        String   @unique
  discountAmount Float
  usedAt         DateTime @default(now())

  coupon   Coupon    @relation(fields: [couponId], references: [id], onDelete: Restrict)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([customerId])
  @@index([phone])
}

model CouponLock {
  id        String   @id @default(uuid())
  couponId  String
  phone     String?
  sessionId String
  expiresAt DateTime
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([expiresAt])
  @@index([sessionId])
  @@index([phone])
}

model OrderItem {
  id            String          @id @default(uuid())
  orderId       String
  productId     String
  quantity      Int
  price         Float
  printCost     Float           @default(0)
  printName     String?
  printNumber   String?
  requiresPrint Boolean         @default(false)
  size          String          @default("M")
  variantId     String?
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)
  salesReturns  SalesReturn[]

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model DeliverySetting {
  id           String   @id @default("default")
  insideDhaka  Int      @default(80)
  outsideDhaka Int      @default(150)
  posFooter    String   @default("Thank you for shopping with Mystic. We hope you love your purchase!")
  updatedAt    DateTime @updatedAt
}

model InventorySetting {
  id                String   @id @default("default")
  lowStockThreshold Int      @default(5)
  updatedAt         DateTime @updatedAt
}

model DTFPrintSetting {
  id        String   @id @default("default")
  printCost Int      @default(300)
  updatedAt DateTime @updatedAt
}

model HeroSlide {
  id        String   @id @default(uuid())
  image     String
  link      String   @default("/shop")
  label     String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

model Purchase {
  id             String         @id @default(uuid())
  supplierName   String
  supplierId     String?
  invoiceNumber  String?
  totalAmount    Float
  status         String         @default("PENDING")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  discountAmount Float          @default(0)
  items          PurchaseItem[]
  supplier       Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([deletedAt])
  @@index([supplierId])
}

model Supplier {
  id         String     @id @default(uuid())
  name       String     @unique
  phone      String?
  address    String?
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?
  purchases  Purchase[]

  @@index([deletedAt])
}

model PurchaseItem {
  id         String         @id @default(uuid())
  purchaseId String
  productId  String
  variantId  String
  quantity   Int
  unitPrice  Float
  product    Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  purchase   Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id])

  @@index([purchaseId])
  @@index([productId])
}

model FooterConfig {
  id             String   @id @default("default")
  aboutText      String   @default("Premium authentic jerseys and sportswear. Crafted for those who live and breathe the game.")
  facebookUrl    String   @default("#")
  instagramUrl   String   @default("#")
  whatsappPhone  String?  @default("")
  companyLinks   Json     @default("[{\"url\": \"/about\", \"label\": \"About\"}, {\"url\": \"/contact\", \"label\": \"Contact\"}, {\"url\": \"/faq\", \"label\": \"FAQ\"}]")
  contactEmail   String   @default("hello@mysticfashion.com")
  contactPhone   String   @default("01700-MYSTIC")
  contactAddress String   @default("Dhaka, Bangladesh")
  updatedAt      DateTime @updatedAt
}

model Page {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChartOfAccount {
  id           String        @id @default(uuid())
  name         String        @unique
  type         AccountType
  status       AccountStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  journalLines JournalLine[]

  @@index([name])
}

model Transaction {
  id            String          @id @default(uuid())
  accountId     String
  amount        Float
  date          DateTime
  type          TransactionType
  description   String
  referenceId   String?
  referenceType String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  account       ChartOfAccount  @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([accountId])
  @@index([referenceId])
}

model JournalEntry {
  id            String        @id @default(uuid())
  date          DateTime
  description   String
  referenceId   String?
  referenceType String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  lines         JournalLine[]
}

model JournalLine {
  id             String          @id @default(uuid())
  journalEntryId String
  accountId      String
  amount         Float
  type           TransactionType
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  journalEntry   JournalEntry    @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        ChartOfAccount  @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([accountId])
  @@index([journalEntryId])
}

model ApiToken {
  id           String   @id @default("pathao")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt
}

model StockAdjustment {
  id               String         @id @default(uuid())
  variantId        String
  adjustmentType   AdjustmentType
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  reason           String?
  adjustedBy       String?
  createdAt        DateTime       @default(now())
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model SalesReturn {
  id           String         @id @default(uuid())
  orderId      String
  orderItemId  String
  variantId    String
  quantity     Int
  returnReason String
  status       ReturnStatus
  deliveryLoss Float          @default(0)
  productLoss  Float          @default(0)
  printingLoss Float          @default(0)
  returnCost     Float   @default(0)
  returnCostPaid Boolean @default(false)
  processedBy  String?
  createdAt    DateTime       @default(now())
  order        Order          @relation(fields: [orderId], references: [id])
  orderItem    OrderItem      @relation(fields: [orderItemId], references: [id])
  variant      ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([orderItemId])
}

model LabelSetting {
  id          String   @id @default("default")
  widthMm     Int      @default(50)
  heightMm    Int      @default(25)
  showName    Boolean  @default(true)
  showPrice   Boolean  @default(true)
  showSKU     Boolean  @default(true)
  showBarcode Boolean  @default(true)
  showQR      Boolean  @default(false)
  fontSize    Int      @default(8)
  updatedAt   DateTime
}

enum DiscountType {
  FLAT
  PERCENTAGE
}

enum CouponType {
  FLAT
  PERCENTAGE
  FREE_SHIPPING
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKAGING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  PRINTING
  HOLD
}

enum OrderSource {
  eCommerce
  Salesman
}

enum AdminRole {
  SUPERADMIN
  MANAGER
}

enum AccountType {
  INCOME
  EXPENSE
  ASSET
  LIABILITY
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum TransactionType {
  DEBIT
  CREDIT
}

enum AdjustmentType {
  ADDITION
  SUBTRACTION
  SET
}

enum ReturnStatus {
  RESTOCKED
  WASTAGE
}

// ─── AUDIT TRAIL ──────────────────────────────────────────────────────────────

model ActivityLog {
  id            String      @id @default(uuid())

  // ─── WHO ─────────────────────────────────────────────────
  userId        String                    // Staff/Admin UUID
  userEmail     String?                   // Denormalized for quick display
  userRole      String?                   // e.g. "SUPERADMIN", "MANAGER"

  // ─── WHAT ────────────────────────────────────────────────
  action        AuditAction               // CREATE, UPDATE, DELETE
  entityType    String                    // e.g. "Product", "Order", "Transaction"
  entityId      String                    // The UUID/ID of the affected record
  description   String?                   // Human-readable summary
  dataBefore    Json?                     // JSONB snapshot BEFORE mutation (null for CREATE)
  dataAfter     Json?                     // JSONB snapshot AFTER mutation (null for DELETE)
  changedFields String[]                  // Array of field names that changed (for UPDATE)

  // ─── WHEN ────────────────────────────────────────────────
  timestamp     DateTime    @default(now())

  // ─── WHERE ───────────────────────────────────────────────
  ipAddress     String?                   // Extracted from request headers
  userAgent     String?                   // Browser/device info

  // ─── INDEXING ────────────────────────────────────────────
  @@index([userId])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@index([action])
}

model AuditLogSetting {
  id                String   @id @default("default")
  retentionDays     Int?                  // null = keep indefinitely (default)
  updatedAt         DateTime @updatedAt
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model Customer {
  id           String            @id @default(uuid())
  name         String
  phone        String            @unique
  address      String?
  email        String?           @unique
  passwordHash String?
  isActive     Boolean           @default(true)
  otpCode      String?
  otpExpiresAt DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  orders       Order[]
  addresses    CustomerAddress[]
  couponUsages CouponUsage[]
}

model CustomerAddress {
  id           String   @id @default(uuid())
  customerId   String
  label        String   // e.g., 'Home', 'Office'
  fullName     String
  phone        String
  district     String
  address      String
  pathaoCityId Int?
  pathaoZoneId Int?
  pathaoAreaId Int?
  zoneName     String?
  areaName     String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}



model CancellationRequest {
  id        String   @id @default(uuid())
  orderId   String   @unique
  staffName String
  reason    String?
  createdAt DateTime @default(now())
}

model Warehouse {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  address   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stocks    Stock[]
}

model Stock {
  id                String             @id @default(uuid())
  variantId         String
  warehouseId       String
  physicalQuantity  Int                @default(0)
  reservedQuantity  Int                @default(0)
  availableQuantity Int                @default(0)
  version           Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  variant           ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse         Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  ledgerEntries     StockLedgerEntry[]

  @@unique([variantId, warehouseId])
  @@index([variantId])
  @@index([warehouseId])
}

enum StockMovementType {
  RECEIPT
  SALE
  RETURN
  TRANSFER
  ADJUSTMENT
}

model StockLedgerEntry {
  id                        String            @id @default(uuid())
  stockId                   String
  movementType              StockMovementType
  quantity                  Int
  previousPhysicalQuantity  Int
  previousAvailableQuantity Int
  newPhysicalQuantity       Int
  newAvailableQuantity      Int
  referenceId               String?
  referenceType             String?
  createdAt                 DateTime          @default(now())
  stock                     Stock             @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId])
  @@index([createdAt])
}

model VariantPricingMatrix {
  id         String         @id @default(uuid())
  variantId  String         @unique
  costPrice  Decimal?       @db.Decimal(12, 2)
  basePrice  Decimal        @db.Decimal(12, 2)
  msrp       Decimal?       @db.Decimal(12, 2)
  b2bPrice   Decimal?       @db.Decimal(12, 2)
  tierPrices Json           @default("{}")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model AttributeRegistry {
  id               String                     @id @default(uuid())
  code             String                     @unique
  name             String
  type             String                     @default("TEXT")
  description      String?
  presets          Json                       @default("[]")
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  categoryMappings CategoryAttributeMapping[]
}

model CategoryAttributeMapping {
  id          String            @id @default(uuid())
  categoryId  String
  attributeId String
  isRequired  Boolean           @default(false)
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  category    Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attribute   AttributeRegistry @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([categoryId, attributeId])
  @@index([categoryId])
  @@index([attributeId])
}

model MediaAsset {
  id              String   @id @default(uuid())
  productId       String
  url             String
  sortOrder       Int      @default(0)
  altText         String?
  boundAttributes Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}
