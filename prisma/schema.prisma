generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Discount {
  id           String       @id @default(uuid())
  name         String
  discountType DiscountType @default(FLAT)
  value        Float
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
  products     Product[]

  @@index([deletedAt])
}

model Admin {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      AdminRole @default(MANAGER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  roleId    String?
  rbacRole  Role?     @relation(fields: [roleId], references: [id])
}

model Staff {
  id                 String              @id @default(uuid())
  username           String              @unique
  email              String              @unique
  password           String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  roleId             String?
  commissionRate     Float?
  hasPortalAccess    Boolean             @default(false)
  commissionPayments CommissionPayment[]
  orders             Order[]
  role               Role?               @relation(fields: [roleId], references: [id])
}

model CommissionSetting {
  id             String   @id @default("default")
  commissionRate Float    @default(10)
  updatedAt      DateTime @updatedAt
}

model CommissionPayment {
  id       String   @id @default(uuid())
  staffId  String
  amount   Float
  month    Int
  year     Int
  note     String?
  paidAt   DateTime @default(now())
  paidById String?
  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([year, month])
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  admins      Admin[]
  staff       Staff[]
  permissions Permission[] @relation("PermissionToRole")
}

model Permission {
  id      String @id @default(uuid())
  action  String
  subject String
  roles   Role[] @relation("PermissionToRole")

  @@unique([action, subject])
}

model SizeChart {
  id        String    @id @default(uuid())
  category  String    @unique
  data      Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  active    Boolean   @default(true)
  deletedAt DateTime?
  products  Product[]

  @@index([deletedAt])
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  image         String?
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  active        Boolean       @default(true)
  deletedAt     DateTime?
  products      Product[]
  subcategories Subcategory[]

  categoryAttributeMappings CategoryAttributeMapping[]

  @@index([deletedAt])
}

model Subcategory {
  id         String    @id @default(uuid())
  name       String
  categoryId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  active     Boolean   @default(true)
  deletedAt  DateTime?
  products   Product[]
  category   Category  @relation(fields: [categoryId], references: [id])

  @@unique([name, categoryId])
  @@index([categoryId])
  @@index([deletedAt])
}

model Product {
  id            String           @id @default(uuid())
  name          String
  description   String
  price         Float
  purchasePrice Float?
  images        String[]
  team          String?
  category      String
  sizeChartId   String?
  discountId    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  isFeatured    Boolean          @default(false)
  featuredOrder Int              @default(0)
  isPublished   Boolean          @default(true)
  brandId       String?
  categoryId    String?
  subcategoryId String?
  isCustomize   Boolean?         @default(false)
  slug          String?          @unique
  deletedAt     DateTime?
  trackStock    Boolean?         @default(false)
  orderItems    OrderItem[]
  brand         Brand?           @relation(fields: [brandId], references: [id])
  categoryRel   Category?        @relation(fields: [categoryId], references: [id])
  discount      Discount?        @relation(fields: [discountId], references: [id])
  sizeChart     SizeChart?       @relation(fields: [sizeChartId], references: [id])
  subcategory   Subcategory?     @relation(fields: [subcategoryId], references: [id])
  variants      ProductVariant[]
  purchaseItems PurchaseItem[]
  //relation media asstes 
  mediaAssets   MediaAsset[] // Multi-image support

  @@index([deletedAt])
  @@index([brandId])
  @@index([categoryId])
  @@index([subcategoryId])
}

model ProductVariant {
  id               String            @id @default(uuid())
  productId        String
  size             String
  stock            Int               @default(0)
  order            Int               @default(0)
  color            String            @default("Default")
  colorCode        String?
  sku              String?           @unique
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchaseItems    PurchaseItem[]
  salesReturns     SalesReturn[]
  stockAdjustments StockAdjustment[]

  //Relation
  attributes    Json?                 @default("{}")
  pricingMatrix VariantPricingMatrix?

  @@unique([productId, size, color])
  @@index([productId])
}

model Order {
  id                  String        @id @default(uuid())
  customerName        String
  phone               String
  district            String        @default("Dhaka")
  address             String
  totalAmount         Float
  status              OrderStatus   @default(PENDING)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  advancePaid         Float         @default(0)
  couponCode          String?
  discountAmount      Float         @default(0)
  remarks             String?
  bkashNumber         String?
  bkashTrxId          String?
  pathaoAreaId        Int?
  pathaoCityId        Int?
  pathaoConsignmentId String?
  pathaoZoneId        Int?
  orderSource         OrderSource   @default(Salesman)
  createdById         String?
  customerId          String?
  deliveryCharge      Float         @default(0)
  exchangeItemNote    String?
  exchangeRefOrderId  String?
  isExchange          Boolean       @default(false)
  isStorePickup       Boolean       @default(false)
  deletedAt           DateTime?
  commissionRate      Float?
  tags                String[]      @default([])
  couponUsage         CouponUsage?
  coupon              Coupon?       @relation(fields: [couponCode], references: [code])
  createdBy           Staff?        @relation(fields: [createdById], references: [id])
  customer            Customer?     @relation(fields: [customerId], references: [id])
  exchangeRefOrder    Order?        @relation("ExchangeOrders", fields: [exchangeRefOrderId], references: [id])
  exchangeOrders      Order[]       @relation("ExchangeOrders")
  items               OrderItem[]
  salesReturns        SalesReturn[]

  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([customerId])
  @@index([phone])
}

model Coupon {
  id                  String        @id @default(cuid())
  code                String        @unique
  type                CouponType    @default(FLAT)
  value               Float
  startDate           DateTime?
  endDate             DateTime?
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?
  customerSegment     String?
  excludeSaleItems    Boolean       @default(false)
  excludedCategoryIds String[]      @default([])
  excludedProductIds  String[]      @default([])
  includedCategoryIds String[]      @default([])
  includedProductIds  String[]      @default([])
  maxCartValue        Float?
  maxDiscountAmount   Float?
  minCartValue        Float?
  usageLimitPerUser   Int           @default(1)
  usageLimitTotal     Int?
  locks               CouponLock[]
  usages              CouponUsage[]
  orders              Order[]

  @@index([deletedAt])
}

model CouponUsage {
  id             String    @id @default(uuid())
  couponId       String
  customerId     String?
  phone          String
  orderId        String    @unique
  discountAmount Float
  usedAt         DateTime  @default(now())
  coupon         Coupon    @relation(fields: [couponId], references: [id])
  customer       Customer? @relation(fields: [customerId], references: [id])
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([customerId])
  @@index([phone])
}

model CouponLock {
  id        String   @id @default(uuid())
  couponId  String
  phone     String?
  sessionId String
  expiresAt DateTime
  createdAt DateTime @default(now())
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([expiresAt])
  @@index([sessionId])
  @@index([phone])
}

model OrderItem {
  id            String        @id @default(uuid())
  orderId       String
  productId     String
  size          String        @default("M")
  quantity      Int
  price         Float
  printCost     Float         @default(0)
  printName     String?
  printNumber   String?
  requiresPrint Boolean       @default(false)
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
  salesReturns  SalesReturn[]

  @@index([orderId])
  @@index([productId])
}

model DeliverySetting {
  id           String   @id @default("default")
  insideDhaka  Int      @default(80)
  outsideDhaka Int      @default(150)
  updatedAt    DateTime @updatedAt
}

model InventorySetting {
  id                String   @id @default("default")
  lowStockThreshold Int      @default(5)
  updatedAt         DateTime @updatedAt
}

model DTFPrintSetting {
  id        String   @id @default("default")
  printCost Int      @default(300)
  updatedAt DateTime @updatedAt
}

model HeroSlide {
  id        String    @id @default(uuid())
  image     String
  link      String    @default("/shop")
  label     String?
  sortOrder Int       @default(0)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

model Purchase {
  id             String         @id @default(uuid())
  supplierName   String
  invoiceNumber  String?
  totalAmount    Float
  status         String         @default("PENDING")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  discountAmount Float          @default(0)
  supplierId     String?
  deletedAt      DateTime?
  supplier       Supplier?      @relation(fields: [supplierId], references: [id])
  items          PurchaseItem[]

  @@index([deletedAt])
  @@index([supplierId])
}

model Supplier {
  id        String     @id @default(uuid())
  name      String     @unique
  phone     String?
  address   String?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  purchases Purchase[]

  @@index([deletedAt])
}

model PurchaseItem {
  id         String         @id @default(uuid())
  purchaseId String
  productId  String
  variantId  String
  quantity   Int
  unitPrice  Float
  product    Product        @relation(fields: [productId], references: [id])
  purchase   Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id])

  @@index([purchaseId])
  @@index([productId])
}

model FooterConfig {
  id             String   @id @default("default")
  aboutText      String   @default("Premium authentic jerseys and sportswear. Crafted for those who live and breathe the game.")
  facebookUrl    String   @default("#")
  instagramUrl   String   @default("#")
  whatsappPhone  String?  @default("")
  companyLinks   Json     @default("[{\"url\": \"/about\", \"label\": \"About\"}, {\"url\": \"/contact\", \"label\": \"Contact\"}, {\"url\": \"/faq\", \"label\": \"FAQ\"}]")
  contactEmail   String   @default("hello@mysticfashion.com")
  contactPhone   String   @default("01700-MYSTIC")
  contactAddress String   @default("Dhaka, Bangladesh")
  updatedAt      DateTime @updatedAt
}

model Page {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChartOfAccount {
  id           String        @id @default(uuid())
  name         String        @unique
  type         AccountType
  status       AccountStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  journalLines JournalLine[]
  transactions Transaction[]

  @@index([name])
}

model Transaction {
  id            String          @id @default(uuid())
  accountId     String
  amount        Float
  date          DateTime
  type          TransactionType
  description   String
  referenceId   String?
  referenceType String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  account       ChartOfAccount  @relation(fields: [accountId], references: [id])

  @@index([accountId])
  @@index([referenceId])
}

model JournalEntry {
  id            String        @id @default(uuid())
  date          DateTime
  description   String
  referenceId   String?
  referenceType String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  lines         JournalLine[]
}

model JournalLine {
  id             String          @id @default(uuid())
  journalEntryId String
  accountId      String
  amount         Float
  type           TransactionType
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  account        ChartOfAccount  @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry    @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([journalEntryId])
}

model ApiToken {
  id           String   @id @default("pathao")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt
}

model StockAdjustment {
  id               String         @id @default(uuid())
  variantId        String
  adjustmentType   AdjustmentType
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  reason           String?
  adjustedBy       String?
  createdAt        DateTime       @default(now())
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model SalesReturn {
  id             String         @id @default(uuid())
  orderId        String
  orderItemId    String
  variantId      String
  quantity       Int
  returnReason   String
  status         ReturnStatus
  deliveryLoss   Float          @default(0)
  productLoss    Float          @default(0)
  printingLoss   Float          @default(0)
  processedBy    String?
  createdAt      DateTime       @default(now())
  returnCost     Float          @default(0)
  returnCostPaid Boolean        @default(false)
  order          Order          @relation(fields: [orderId], references: [id])
  orderItem      OrderItem      @relation(fields: [orderItemId], references: [id])
  variant        ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([orderItemId])
}

model LabelSetting {
  id          String   @id @default("default")
  widthMm     Int      @default(50)
  heightMm    Int      @default(25)
  showName    Boolean  @default(true)
  showPrice   Boolean  @default(true)
  showSKU     Boolean  @default(true)
  showBarcode Boolean  @default(true)
  showQR      Boolean  @default(false)
  fontSize    Int      @default(8)
  updatedAt   DateTime
}

model ActivityLog {
  id            String      @id @default(uuid())
  userId        String
  userEmail     String?
  userRole      String?
  action        AuditAction
  entityType    String
  entityId      String
  description   String?
  dataBefore    Json?
  dataAfter     Json?
  changedFields String[]
  timestamp     DateTime    @default(now())
  ipAddress     String?
  userAgent     String?

  @@index([userId])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@index([action])
}

model AuditLogSetting {
  id            String   @id @default("default")
  retentionDays Int?
  updatedAt     DateTime @updatedAt
}

model Customer {
  id           String            @id @default(uuid())
  name         String
  phone        String            @unique
  address      String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  email        String?           @unique
  isActive     Boolean           @default(true)
  otpCode      String?
  otpExpiresAt DateTime?
  passwordHash String?
  couponUsages CouponUsage[]
  addresses    CustomerAddress[]
  orders       Order[]
}

model CustomerAddress {
  id           String   @id @default(uuid())
  customerId   String
  label        String
  fullName     String
  phone        String
  district     String
  address      String
  pathaoCityId Int?
  pathaoZoneId Int?
  pathaoAreaId Int?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

enum DiscountType {
  FLAT
  PERCENTAGE
}

enum CouponType {
  FLAT
  PERCENTAGE
  FREE_SHIPPING
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKAGING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  PRINTING
}

enum OrderSource {
  eCommerce
  Salesman
}

enum AdminRole {
  SUPERADMIN
  MANAGER
}

enum AccountType {
  INCOME
  EXPENSE
  ASSET
  LIABILITY
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum TransactionType {
  DEBIT
  CREDIT
}

enum AdjustmentType {
  ADDITION
  SUBTRACTION
  SET
}

enum ReturnStatus {
  RESTOCKED
  WASTAGE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

//PIM ENUMS
enum AttributeType {
  TEXT
  NUMBER
  DROPDOWN
  COLOR
  BOOLEAN
}

// ──   AttributeRegistry ──────────────────────────────────────────────────

model AttributeRegistry {
  id        String        @id @default(uuid())
  code      String        @unique
  name      String
  type      AttributeType @default(DROPDOWN)
  presets   Json?
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relations
  categoryMappings CategoryAttributeMapping[]

  @@index([code])
}

// ──  CategoryAttributeMapping ───────────────────────────────────────────

model CategoryAttributeMapping {
  id          String   @id @default(uuid())
  categoryId  String
  attributeId String
  isRequired  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  // Relations
  category  Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attribute AttributeRegistry @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([categoryId, attributeId])
  @@index([categoryId])
}

// ──  VariantPricingMatrix ────────────────────────────────────────────────

model VariantPricingMatrix {
  id        String @id @default(uuid())
  variantId String @unique // ProductVariant 

  costPrice  Decimal? @db.Decimal(10, 2) // WAC calculated,  
  basePrice  Decimal? @db.Decimal(10, 2)
  msrp       Decimal? @db.Decimal(10, 2) //  MRP
  b2bPrice   Decimal? @db.Decimal(10, 2)
  tierPrices Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
}

model MediaAsset {
  id              String   @id @default(uuid())
  productId       String
  url             String // image path or URL
  altText         String? // optional alt text for accessibility
  isPrimary       Boolean  @default(false) // main image for product
  sortOrder       Int      @default(0)
  boundAttributes Json? // e.g., {"color": "Red"} or {"size": "L", "color": "Blue"}
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, url])
  @@index([productId])
}
