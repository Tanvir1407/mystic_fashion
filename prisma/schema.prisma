// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DiscountType {
  FLAT
  PERCENTAGE
}

enum CouponType {
  FLAT
  PERCENTAGE
}

model Discount {
  id           String       @id @default(uuid())
  name         String       // Name or promo code identifier
  discountType DiscountType @default(FLAT)
  value        Float        // e.g. 20 (for 20% or 20 BDT)
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  products     Product[]
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKAGING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum AdminRole {
  SUPERADMIN
  MANAGER
}

model Admin {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      AdminRole @default(MANAGER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Staff {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SizeChart {
  id        String    @id @default(uuid())
  category  String    @unique
  data      Json
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id            String   @id @default(uuid())
  name          String
  description   String
  price         Float
  purchasePrice Float?   // Updated dynamically from purchases
  images        String[]
  team          String
  category      String
  isFeatured    Boolean  @default(false)
  
  sizeChartId   String?
  sizeChart     SizeChart? @relation(fields: [sizeChartId], references: [id])

  discountId    String?
  discount      Discount? @relation(fields: [discountId], references: [id])

  variants      ProductVariant[]
  orderItems    OrderItem[]
  purchaseItems PurchaseItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  size      String   
  stock     Int      @default(0)

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchaseItems PurchaseItem[]

  @@unique([productId, size])
}

model Order {
  id           String      @id @default(uuid())
  customerName String
  phone        String
  district     String      @default("Dhaka")
  address      String
  totalAmount  Float
  advancePaid    Float       @default(0)
  status         OrderStatus @default(PENDING)
  bkashNumber    String?
  bkashTrxId     String?
  remarks        String?
  couponCode   String?
  discountAmount Float       @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  items OrderItem[]
  coupon   Coupon? @relation(fields: [couponCode], references: [code])
}

model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique
  type        CouponType @default(FLAT)
  value       Float
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  orders      Order[]
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  size      String   @default("M") // Required to know which variant to fulfill
  quantity  Int
  price     Float    // Storing price at time of purchase

  // DTF Printing Fields
  requiresPrint Boolean @default(false)
  printName     String?
  printNumber   String?
  printCost     Float   @default(0)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model DeliverySetting {
  id           String   @id @default("default")
  insideDhaka  Int      @default(80)
  outsideDhaka Int      @default(150)
  updatedAt    DateTime @updatedAt
}

model InventorySetting {
  id                String   @id @default("default")
  lowStockThreshold Int      @default(5)
  updatedAt         DateTime @updatedAt
}

model HeroSlide {
  id        String   @id @default(uuid())
  image     String
  link      String   @default("/shop")
  label     String?  // Optional text label for the slide
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Purchase {
  id            String   @id @default(uuid())
  supplierName  String
  invoiceNumber String?
  totalAmount    Float
  discountAmount Float    @default(0)
  status         String   @default("PENDING") // PENDING, COMPLETED, CANCELLED
  items          PurchaseItem[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PurchaseItem {
  id            String   @id @default(uuid())
  purchaseId    String
  productId     String
  variantId     String  
  quantity      Int
  unitPrice     Float   
  
  purchase      Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product       Product        @relation(fields: [productId], references: [id])
  variant       ProductVariant @relation(fields: [variantId], references: [id])
}

model FooterConfig {
  id            String   @id @default("default")
  aboutText     String   @default("Premium authentic jerseys and sportswear. Crafted for those who live and breathe the game.")
  facebookUrl   String   @default("#")
  instagramUrl  String   @default("#")
  whatsappPhone String?  @default("")
  
  // Quick Links (JSON)
  companyLinks  Json     @default("[{\"label\": \"About\", \"url\": \"/about\"}, {\"label\": \"Contact\", \"url\": \"/contact\"}, {\"label\": \"FAQ\", \"url\": \"/faq\"}]")
  
  contactEmail   String   @default("hello@mysticfashion.com")
  contactPhone   String   @default("01700-MYSTIC")
  contactAddress String   @default("Dhaka, Bangladesh")

  updatedAt     DateTime @updatedAt
}

model Page {
  id        String   @id @default(uuid())
  slug      String   @unique // about, contact, faq, privacy, terms
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
